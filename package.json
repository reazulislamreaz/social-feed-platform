{
  "name": "taskbook",
  "version": "1.0.0",
  "private": true,
  "description": "Social feed platform — posts, comments, replies, likes",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
