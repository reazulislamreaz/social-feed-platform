PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# local (default) or s3 (R2 / S3-compatible)
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
# PUBLIC_ASSET_BASE_URL=https://cdn.example.com

# Required when STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://cdn.example.com

# Optional — short-lived feed page cache
# Use a real URL (not a redis-cli command). Upstash needs rediss:// (TLS).
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=rediss://default:PASSWORD@YOUR-endpoint.upstash.io:6379
FEED_CACHE_TTL_SECONDS=20
