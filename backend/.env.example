PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# local (dev) or s3 (production / multi-instance)
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Public API origin — required in production when frontend is on another host
# so /uploads/... becomes https://reaz.sellx.no/uploads/...
# PUBLIC_API_URL=https://reaz.sellx.no

# Optional CDN
# PUBLIC_ASSET_BASE_URL=https://cdn.example.com

# Required when STORAGE_DRIVER=s3 (Cloudflare R2 example)
# S3_BUCKET=taskbook-uploads
# S3_REGION=auto
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://cdn.example.com

# Optional Redis
# REDIS_URL=rediss://default:PASSWORD@YOUR-endpoint.upstash.io:6379
FEED_CACHE_TTL_SECONDS=20
