PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# local (dev) or s3 (production — persistent images)
STORAGE_DRIVER=s3
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
PUBLIC_API_URL=https://reaz.sellx.no

# AWS S3 (either S3_* or AWS_* names work)
AWS_S3_BUCKET_NAME=your-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# Optional CDN in front of the bucket
# S3_PUBLIC_URL=https://cdn.example.com

# Optional Redis
# REDIS_URL=rediss://default:PASSWORD@YOUR-endpoint.upstash.io:6379
FEED_CACHE_TTL_SECONDS=20
